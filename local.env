# Local development environment.
#
# This file is checked in and used directly for local development.
# It is loaded by compose.yaml and can be used by the app via --env-file or similar.

# Local Postgres connection (matches compose.yaml)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/office_map

# Must match the value in supabase/seed_local_dev.sql for seeded PIN login to work
PIN_PEPPER=local-dev-pepper

# Skip auth for local kiosk/API development
REQUIRE_AUTH=false

# Use in-memory Graph stub instead of real Microsoft Graph
GRAPH_BACKEND=stub

PUBLIC_AUTH_MAX_AGE_DAYS=30

# Seeded local users from supabase/seed_local_dev.sql:
# - dev-booker@example.test -> PIN 1234
# - dev-admin@example.test  -> PIN 4321
# - dev-locked@example.test -> PIN 9999 (locked)
