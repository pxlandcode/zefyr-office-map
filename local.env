# Used for local development & automated testsing

# Use in-memory Graph stub instead of real Microsoft Graph
GRAPH_BACKEND=stub
# For production, these need to be provided:

CLIENT_ID=client-id-graph-stub
TENANT_ID=tenant-id-graph-stub
CLIENT_SECRET=client-secret-graph-stub
# TODO: Double-check this field is still in use
ACCOUNT_USERNAME=user@graph-stub
# TODO: Double-check this field is stil in use
ACCOUNT_PASSWORD=pw-graph-stub
GRAPH_SCOPES=scopes-graph-stub

# Local Postgres connection (matches compose.yaml)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/office_map
# TODO: This is not consistent FIX!
# PUBLIC_SUPABASE_URL & PUBLIC_SUPABASE_ANON_KEY used by production code
PUBLIC_SUPABASE_URL=TODO
PUBLIC_SUPABASE_ANON_KEY=TODO

# Must match the value in supabase/seed_local_dev.sql for seeded PIN login to work
PIN_PEPPER=local-dev-pepper

# Skip auth for local kiosk/API development
DISPLAY_EMAIL=local@example.test
GATEWAY_EMAIL=local@example.test

REQUIRE_AUTH=false
PUBLIC_AUTH_MAX_AGE_DAYS=30

# Seeded local users from supabase/seed_local_dev.sql:
# - dev-booker@example.test -> PIN 1234
# - dev-admin@example.test  -> PIN 4321
# - dev-locked@example.test -> PIN 9999 (locked)
